# Variáveis para rodar o backend FORA do Docker (conecta em localhost)
# Banco e MinIO precisam estar rodando via: docker compose up postgres minio -d
DATABASE_URL=postgres://aldeia:secret@localhost:5432/aldeia_indica?sslmode=disable
JWT_SECRET=aldeia-indica-dev-secret-32-bytes-ok
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h
PORT=8080
LOG_LEVEL=info

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_BUCKET_PUBLIC=aldeia-public
AWS_BUCKET_PRIVATE=aldeia-private
AWS_ENDPOINT=http://localhost:9000
CLOUDFRONT_BASE_URL=http://localhost:9000/aldeia-public

FCM_SERVICE_ACCOUNT_JSON=

RESEND_API_KEY=
FROM_EMAIL=no-reply@aldeiaindica.com.br
